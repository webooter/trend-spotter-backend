# Copy these into Railway → Variables tab

# YouTube Data API v3 key (free, 10k units/day)
# Get it at: console.cloud.google.com → Enable "YouTube Data API v3" → Create credentials → API Key
YOUTUBE_API_KEY=your_youtube_api_key_here

# Spoonacular Recipe API key (free, 150 points/day)
# Sign up at: spoonacular.com/food-api
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# PORT is auto-set by Railway — don't touch this
# PORT=3001
